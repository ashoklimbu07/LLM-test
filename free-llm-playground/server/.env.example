# These are optional server-side defaults. Any key entered in the UI's
# "Use your own key" popup overrides these per-request, so the app also
# works with zero server-side keys set — each visitor can bring their own.

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq — https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter (free-tagged models) — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# MongoDB connection string for storing test history/stats.
# Local: mongodb://localhost:27017/llm-playground
# Atlas (free tier): https://www.mongodb.com/cloud/atlas/register
MONGODB_URI=

PORT=3001
